---
import { Save, X } from "@lucide/astro";
import { LANGUAGES } from "../types";
import type { Snippet } from "../types";

interface Props {
  snippet: Snippet;
  error?: string | null;
}

const { snippet, error = null } = Astro.props;
---

<div
  id="edit-modal"
  class="fixed inset-0 bg-black/70 backdrop-blur-sm z-50 hidden items-center justify-center"
>
  <div
    class="bg-codeshelf-bg border-2 border-codeshelf-border rounded-2xl w-[90%] max-w-4xl max-h-[90vh] overflow-hidden flex flex-col shadow-2xl"
  >
    <!-- HEADER -->
    <div
      class="border-b border-codeshelf-border px-6 py-4 flex justify-between items-center"
    >
      <h2 class="text-2xl text-codeshelf-text">Edit Snippet</h2>
      <button
        id="close-modal"
        class="text-codeshelf-muted hover:text-codeshelf-text transition-colors"
      >
        <X size={25} />
      </button>
    </div>

    <!-- MENSAJE DE ERROR -->
    {
      error && (
        <div class="px-6 pt-4">
          <div class="bg-red-500/10 border border-red-500 text-red-500 px-4 py-3 rounded-lg text-sm">
            {error}
          </div>
        </div>
      )
    }

    <!-- FORMULARIO -->
    <form id="edit-form" method="POST" class="flex-1 overflow-y-auto px-6 py-6">
      <input type="hidden" name="action" value="update" />

      <div class="grid grid-cols-2 gap-6">
        <!-- COLUMNA IZQUIERDA -->
        <div class="space-y-4">
          <div class="flex flex-col">
            <label class="mb-1 text-sm font-semibold text-codeshelf-text">
              Title *
            </label>
            <input
              type="text"
              name="title"
              required
              minlength="3"
              value={snippet.titulo}
              class="bg-codeshelf-panel border border-codeshelf-border rounded-xl py-3 px-4 text-codeshelf-text focus:border-codeshelf-cyan focus:outline-none transition-colors"
            />
          </div>

          <div class="flex flex-col">
            <label class="mb-1 text-sm font-semibold text-codeshelf-text">
              Language *
            </label>
            <select
              name="lenguaje"
              required
              class="bg-codeshelf-panel border border-codeshelf-border rounded-xl py-3 px-4 text-codeshelf-text focus:border-codeshelf-cyan focus:outline-none transition-colors"
            >
              {
                LANGUAGES.map((lang) => (
                  <option
                    value={lang.label}
                    selected={lang.label === snippet.lenguaje}
                  >
                    {lang.label}
                  </option>
                ))
              }
            </select>
          </div>

          <div class="flex flex-col">
            <label class="mb-1 text-sm font-semibold text-codeshelf-text">
              Tags
            </label>
            <input
              type="text"
              name="tags"
              value={snippet.tags.join(", ")}
              placeholder="react, hooks, state"
              class="bg-codeshelf-panel border border-codeshelf-border rounded-xl py-3 px-4 text-codeshelf-text focus:border-codeshelf-cyan focus:outline-none transition-colors"
            />
          </div>

          <div class="flex flex-col">
            <label class="mb-1 text-sm font-semibold text-codeshelf-text">
              Description
            </label>
            <textarea
              name="descripcion"
              rows="4"
              placeholder="Descripción breve del snippet..."
              class="bg-codeshelf-panel border border-codeshelf-border rounded-xl py-3 px-4 text-codeshelf-text focus:border-codeshelf-cyan focus:outline-none transition-colors resize-none"
              >{snippet.descripcion}</textarea
            >
          </div>
        </div>

        <!-- COLUMNA DERECHA - CODE EDITOR -->
        <div class="flex flex-col">
          <label class="mb-1 text-sm font-semibold text-codeshelf-text">
            Code *
          </label>
          <textarea
            name="codigo"
            required
            minlength="10"
            placeholder="// Paste your code here..."
            class="flex-1 bg-codeshelf-panel border border-codeshelf-border rounded-xl py-3 px-4 font-mono text-sm text-codeshelf-text focus:border-codeshelf-cyan focus:outline-none transition-colors resize-none"
            >{snippet.codigo}</textarea
          >
        </div>
      </div>
    </form>

    <!-- FOOTER -->
    <div
      class="border-t border-codeshelf-border px-6 py-4 flex justify-end gap-3"
    >
      <button
        id="cancel-btn"
        type="button"
        class="px-6 py-2.5 rounded-md border border-codeshelf-border text-codeshelf-text hover:bg-codeshelf-panel transition-colors"
      >
        Cancel
      </button>
      <button
        type="submit"
        form="edit-form"
        class="bg-codeshelf-cyan text-black px-6 py-2.5 rounded-md flex items-center gap-2 hover:shadow-[0_0_15px_rgba(0,240,255,0.4)] transition-all active:scale-95 font-semibold"
      >
        <Save size={20} />
        <span>Save Changes</span>
      </button>
    </div>
  </div>
</div>

<script>
  // Este script corre en el cliente para CERRAR
  const modal = document.getElementById("edit-modal");
  const closeBtn = document.getElementById("close-modal");
  const cancelBtn = document.getElementById("cancel-btn");

  const close = () => {
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
  };

  closeBtn?.addEventListener("click", close);
  cancelBtn?.addEventListener("click", close);

  // Cerrar al hacer click en el fondo oscuro
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) close();
  });
</script>
