---
import { Code } from "astro:components";
import Layout from "../../layouts/Layout.astro";
import { ArrowLeft, FileBraces, Trash, Copy, Edit } from "@lucide/astro";
import {
  getSnippetById,
  deleteSnippet,
  updateSnippet,
} from "../../service/snippet.service";
import type { Snippet } from "../../types";
import { LANGUAGES } from "../../types";
import ModalEditSnippet from "../../components/ModalEditSnippet.astro";

const { id } = Astro.params;

// ✅ MOVER ESTO AL INICIO - Buscar snippet ANTES del POST
const snippet = getSnippetById(Number(id)) as Snippet;

if (!snippet) {
  return Astro.redirect("/404");
}

let error: string | null = null;
let showModal = false;

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const action = data.get("action")?.toString();

  // Eliminar snippet
  if (action === "delete") {
    deleteSnippet(Number(id));
    return Astro.redirect("/snippets");
  }

  // Actualizar snippet
  if (action === "update") {
    try {
      const titulo = data.get("title")?.toString().trim();
      const lenguaje = data.get("lenguaje")?.toString().trim();
      const tagsRaw = data.get("tags")?.toString().trim() || "";
      const codigo = data.get("codigo")?.toString().trim();
      const descripcion = data.get("descripcion")?.toString().trim() || "";

      // Validaciones
      if (!titulo || titulo.length < 3) {
        error = "El título debe tener al menos 3 caracteres";
        showModal = true;
      } else if (!lenguaje) {
        error = "Debes seleccionar un lenguaje";
        showModal = true;
      } else if (!codigo || codigo.length < 10) {
        error = "El código debe tener al menos 10 caracteres";
        showModal = true;
      } else {
        // Preparar tags
        const tagsArray = tagsRaw
          .split(",")
          .map((t) => t.trim())
          .filter((t) => t !== "");

        // Actualizar en la BD
        updateSnippet(Number(id), {
          id: Number(id),
          titulo,
          descripcion,
          lenguaje,
          codigo,
          tags: JSON.stringify(tagsArray),
          publico: snippet.publico ? 1 : 0, // ✅ Ahora snippet ya está disponible
          created_at: snippet.created_at,
        });

        // Redirigir a la misma página para ver cambios
        return Astro.redirect(`/snippets/${id}`);
      }
    } catch (err) {
      console.error("Error al actualizar:", err);
      error = "Ocurrió un error al actualizar el snippet.";
      showModal = true;
    }
  }
}

// }

// Líneas del código
const lineas = snippet.codigo.split("\n");

// Formatear fechas
function formatDate(date: string) {
  return new Date(date).toLocaleDateString("es-AR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

// color del lenguaje
const color =
  LANGUAGES.find((l) => l.label === snippet.lenguaje)?.color || "#888";
---

<Layout title={snippet.titulo}>
  <main class="min-h-screen flex">
    <div class="flex w-full">
      <!-- CONTENIDO PRINCIPAL -->
      <div class="flex-1 flex flex-col">
        <!-- HEADER -->
        <div class="border-b-2 border-codeshelf-border px-8 py-4">
          <a
            href="/snippets"
            class="text-codeshelf-muted flex items-center gap-2 hover:text-codeshelf-cyan transition-colors"
          >
            <ArrowLeft size={15} />
            <span>Back to snippets</span>
          </a>

          <div class="py-2.5 flex justify-between items-center">
            <h2 class="text-codeshelf-text text-2xl">{snippet.titulo}</h2>

            <div class="flex gap-2">
              <!-- EDIT -->
              <button
                id="edit-btn"
                class="text-codeshelf-cyan bg-codeshelf-cyan/15 flex items-center gap-2 py-2 px-4 rounded-md hover:ring-1 hover:ring-codeshelf-cyan transition-all duration-300 hover:scale-105 active:scale-95"
              >
                <Edit size={20} />
                <span>Edit</span>
              </button>

              <!-- DELETE -->
              <form
                method="POST"
                onsubmit="return confirm('¿Eliminar este snippet?')"
              >
                <input type="hidden" name="action" value="delete" />
                <button
                  id="delete-btn"
                  class="text-destructive bg-destructive/15 flex items-center gap-2 py-2 px-4 rounded-md hover:ring-1 hover:ring-destructive transition-all duration-300 hover:scale-105 active:scale-95"
                >
                  <Trash size={20} />
                  <span>Delete</span>
                </button>
              </form>
            </div>
          </div>

          <div class="text-codeshelf-muted flex items-center gap-2">
            <FileBraces color={color || "#888"} size={18} />
            <span class="text-sm capitalize">{snippet.lenguaje}</span>
          </div>
        </div>

        <!-- CÓDIGO -->
        <div class="flex-1 overflow-y-auto px-8 py-6">
          <div class="max-w-5xl mx-auto">
            <div class="flex flex-col justify-end relative">
              <!-- COPY -->
              <button
                id="copy-btn"
                data-code={snippet.codigo}
                class="flex items-center justify-center gap-2 px-4 py-2 rounded-lg border border-codeshelf-cyan text-codeshelf-cyan text-sm font-bold hover:shadow-[0_0_15px_rgba(0,240,255,0.4)] transition-all active:scale-95 absolute top-0 right-0 z-10"
              >
                <Copy size={20} />
                <span id="copy-text">Copy to Clipboard</span>
              </button>

              <div
                class="border border-codeshelf-border rounded-2xl overflow-hidden mt-12"
              >
                <div class="flex p-6 font-mono text-sm">
                  <!-- NUMEROS -->
                  <div
                    class="pr-4 text-white/20 text-right select-none min-w-10"
                  >
                    {lineas.map((_, i) => <span class="block">{i + 1}</span>)}
                  </div>

                  <!-- CODE -->
                  <div class="code overflow-x-auto w-full">
                    <Code
                      code={snippet.codigo}
                      lang={snippet.lenguaje.toLowerCase() as any}
                      theme="one-dark-pro"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- SIDEBAR -->
      <div class="border-l-2 border-codeshelf-border p-6 w-80">
        <h4 class="text-codeshelf-text text-2xl mb-4">Details</h4>

        <div class="py-4">
          <p class="text-sm text-codeshelf-muted mb-1">Created</p>
          <p class="text-codeshelf-text">
            {formatDate(snippet.created_at)}
          </p>
        </div>

        {
          snippet.descripcion && (
            <div class="pb-4">
              <p class="text-sm text-codeshelf-muted mb-2">Description</p>
              <p class="text-codeshelf-text text-sm">{snippet.descripcion}</p>
            </div>
          )
        }

        <!-- TAGS -->
        <div class="pb-4">
          <p class="text-sm text-codeshelf-muted mb-3">Tags</p>

          <div class="flex flex-wrap gap-2">
            {
              snippet.tags.length > 0 ? (
                snippet.tags.map((tag) => (
                  <span class="bg-codeshelf-purple/10 text-codeshelf-purple text-xs px-2 py-1.5 rounded-sm font-bold">
                    {tag}
                  </span>
                ))
              ) : (
                <span class="text-codeshelf-muted text-sm italic">No tags</span>
              )
            }
          </div>
        </div>

        <div class="pb-4">
          <p class="text-sm text-codeshelf-muted mb-1">Lines of code</p>
          <p class="text-codeshelf-text font-mono">{lineas.length}</p>
        </div>
      </div>
    </div>
  </main>

  <!-- MODAL EDIT -->
  <ModalEditSnippet snippet={snippet} error={error} />
</Layout>

<script>
  // Función principal
  const setup = () => {
    const editBtn = document.getElementById("edit-btn");
    const modal = document.getElementById("edit-modal");
    const copyBtn = document.getElementById("copy-btn");

    // 1. Lógica Editar
    if (editBtn && modal) {
      editBtn.addEventListener("click", () => {
        modal.classList.remove("hidden");
        modal.classList.add("flex");
      });
    }

    // 2. Lógica para reabrir si hubo error (leemos el atributo del DOM)
    const mainElement = document.querySelector("main[data-show-modal]");
    const shouldShow = mainElement?.getAttribute("data-show-modal") === "true";

    if (shouldShow && modal) {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }

    // 3. Lógica Copiar
    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        const code = copyBtn.getAttribute("data-code");
        const copyText = document.getElementById("copy-text");
        if (!code || !copyText) return;

        try {
          await navigator.clipboard.writeText(code);
          copyText.textContent = "¡Copiado!";
          setTimeout(() => {
            copyText.textContent = "Copy to Clipboard";
          }, 2000);
        } catch (err) {
          console.error("Error:", err);
        }
      });
    }
  };

  // Correr al cargar
  setup();
  // Correr si usas ViewTransitions
  document.addEventListener("astro:after-swap", setup);
</script>
