---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inicio">
  <main
    class="min-h-screen bg-gray-950 text-white flex flex-col items-center justify-center px-4"
  >
    <div class="max-w-2xl text-center">
      <h1 class="text-5xl font-bold mb-4 text-purple-400">CodeShelf</h1>
      <p class="text-gray-400 text-lg mb-8">
        Tu biblioteca personal de snippets y generador de README con IA
      </p>
      <div class="flex gap-4 justify-center">
        <a
          href="/snippets"
          class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-lg font-medium transition-colors"
        >
          Ver snippets
        </a>
        <a
          href="/readme"
          class="border border-purple-600 hover:bg-purple-600/10 text-purple-400 px-6 py-3 rounded-lg font-medium transition-colors"
        >
          Generar README
        </a>
      </div>
    </div>
  </main>
</Layout>
