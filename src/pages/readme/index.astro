---
// AIReadme.astro
import CardSnippet from "../../components/CardSnippet.astro";
import { SNIPPETS_DATA } from "../../data/snippets";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Readme">
  <div class="w-full mx-auto">
    <div class="mb-8 space-y-2 border-b-2 border-codeshelf-border px-12 py-4">
      <h2 class="text-3xl font-bold text-white tracking-tight">
        <span class="text-codeshelf-cyan">AI</span> README Generator
      </h2>
      <p class="text-codeshelf-muted">
        Describe your project to generate a comprehensive README
      </p>
    </div>

    <div
      class="max-w-4xl bg-[#1A1A1D] border border-white/5 rounded-2xl p-6 mb-10 shadow-2xl mx-auto"
    >
      <label
        class="block text-sm font-medium text-codeshelf-cyan mb-3 uppercase tracking-widest"
      >
        Prompt del Proyecto
      </label>

      <textarea
        id="readme-prompt"
        class="w-full h-64 bg-[#0D0D0F] border border-white/10 rounded-xl p-5 text-white focus:border-codeshelf-cyan outline-none resize-none transition-all placeholder:text-white/10"
        placeholder="Ej: Un dashboard de gestión de inventario para una farmacia. Usamos Astro, Tailwind y SQLite. Necesito una sección de instalación, cómo configurar las variables de entorno y una tabla con las rutas de la API..."
      ></textarea>

      <div class="mt-6 flex items-center justify-between">
        <div class="text-xs text-white/20 font-mono">
          TIP: Sé específico con el stack tecnológico.
        </div>
        <button
          id="generate-readme-btn"
          class="bg-codeshelf-cyan text-black px-8 py-3 rounded-xl font-bold hover:scale-105 transition-all shadow-[0_0_20px_rgba(0,240,255,0.3)] flex items-center gap-2"
        >
          Generar Documentación ✨
        </button>
      </div>
    </div>

    <div id="readme-result-container" class="hidden mt-10 space-y-4">
      <div class="flex justify-between items-center">
        <h3 class="text-white font-medium">README Generado</h3>
        <button
          id="copy-btn"
          class="text-xs text-codeshelf-cyan hover:underline"
          >Copiar Markdown</button
        >
      </div>
      <div
        class="bg-black/40 border border-white/10 rounded-xl p-6 relative group"
      >
        <pre
          id="readme-output"
          class="text-slate-300 text-sm font-mono whitespace-pre-wrap leading-relaxed">
        </pre>
      </div>
    </div>
  </div>
</Layout>

<!-- <style>
  .tab-btn {
    @apply px-6 py-3 text-sm font-medium transition-all border-b-2 -mb-[2px];
  }
  .active-tab {
    @apply border-codeshelf-cyan text-codeshelf-cyan bg-codeshelf-cyan/5;
  }
  .inactive-tab {
    @apply border-transparent text-codeshelf-muted hover:text-codeshelf-text;
  }
</style> -->

<script>
  const btn = document.getElementById("generate-readme-btn");
  const output = document.getElementById("readme-output");
  const container = document.getElementById("readme-result-container");
  const promptInput = document.getElementById("readme-prompt");

  btn?.addEventListener("click", async () => {
    const userPrompt = (promptInput as HTMLTextAreaElement).value;
    if (!userPrompt) return alert("Escribí algo primero!");

    btn.innerText = "Pensando...";
    btn.style.opacity = "0.5";

    try {
      const response = await fetch(
        "https://openrouter.ai/api/v1/chat/completions",
        {
          method: "POST",
          headers: {
            Authorization: `Bearer TU_API_KEY_ACA`, // ⚠️ Usá variables de entorno (.env)
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            model: "google/gemini-2.0-flash-lite-preview-02-05:free",
            messages: [
              {
                role: "system",
                content:
                  "Sos un experto en documentación técnica. Generá un README.md profesional, con emojis, secciones claras (Instalación, Stack, Uso) y formato Markdown impecable basado en la descripción del usuario.",
              },
              { role: "user", content: userPrompt },
            ],
          }),
        },
      );

      const data = await response.json();
      const markdown = data.choices[0].message.content;

      container?.classList.remove("hidden");
      output!.innerText = markdown;
    } catch (error) {
      alert("Hubo un error con la IA");
    } finally {
      btn.innerText = "Generar Documentación ✨";
      btn.style.opacity = "1";
    }
  });
</script>
