---
interface Props {
  title?: string;
}

const { title = "CodeShelf" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — CodeShelf</title>
  </head>
  <body>
    <slot />
  </body>
</html>
